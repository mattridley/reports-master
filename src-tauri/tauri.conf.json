{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Reports Master",
  "version": "0.1.0",
  "identifier": "com.reportsmaster.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Reports Master",
        "width": 1220,
        "height": 820,
        "minWidth": 920,
        "minHeight": 680
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "dmg"],
    "icon": []
  }
}
